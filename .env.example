# Harbor 镜像地址 (在线部署，默认已指向 harbor.zkjgy.online/library，无需修改)
# MCP_IMAGE=harbor.zkjgy.online/library/mcp-music-server:latest

# 离线部署使用本地镜像
# docker load -i mcp-music-server_v0.1.0_linux-amd64.tar.gz
# MCP_IMAGE=mcp-music-server:v0.1.0

# Music directory for local playback
MUSIC_DIR=~/Music

# Server port
MCP_PORT=8090

# Enabled music platforms (comma-separated)
MCP_ENABLED_PLATFORMS=netease,qqmusic,kugou,local

# Transport mode: stdio or sse
MCP_TRANSPORT=sse

# Platform cookies (optional, for VIP/unlocked features)
MCP_NETEASE_COOKIE=
MCP_QQMUSIC_COOKIE=
# QQ Music credential file (run "python qqmusic_login.py" on host first, then uncomment)
# MCP_QQMUSIC_CREDENTIAL_PATH=/app/config/qqmusic_credential.json
MCP_KUGOU_COOKIE=

# Server version (used in labels)
MCP_VERSION=latest
